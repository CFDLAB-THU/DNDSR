#!/bin/bash
# Pre-commit hook: auto-format staged files with clang-format, autopep8,
# and nbstripout. All formatters are optional — if a tool is missing the
# hook prints a warning and continues rather than blocking the commit.
#
# Install:
#   ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
# Or:
#   cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# What it does:
#   - C/C++/CUDA (*.c, *.cc, *.cpp, *.cxx, *.h, *.hpp, *.hxx, *.cu, *.cuh)
#     → clang-format -i (uses the .clang-format at project root)
#   - Python (*.py) → autopep8 --in-place (PEP 8 only, minimal changes)
#   - Jupyter notebooks (*.ipynb) → nbstripout (strip outputs + metadata)
#
# Any files modified by the formatters are re-staged so the commit contains
# the formatted versions.

set -uo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT" || exit 1

# Prefer a venv-local tool if it exists; fall back to PATH.
find_tool()
{
    local name="$1"
    if [ -x "${PROJECT_ROOT}/venv/bin/${name}" ]; then
        echo "${PROJECT_ROOT}/venv/bin/${name}"
        return 0
    fi
    command -v "$name" 2>/dev/null || true
}

# List staged files matching an extension pattern. NUL-safe.
staged_files()
{
    # $1 = extended regex of extensions, e.g. '\.(cpp|hpp)$'
    git diff --cached --name-only --diff-filter=ACMR -z \
        | tr '\0' '\n' \
        | grep -E "$1" || true
}

restage_if_modified()
{
    # Re-stage any of the given paths that the formatter touched.
    # Only re-stage files that were already tracked as staged (don't add new).
    local f
    for f in "$@"; do
        [ -f "$f" ] || continue
        # If working tree version differs from index, re-add.
        if ! git diff --quiet -- "$f"; then
            git add -- "$f"
        fi
    done
}

any_warning=0

# ---- C / C++ / CUDA via clang-format -------------------------------------
CPP_FILES=()
while IFS= read -r line; do
    [ -n "$line" ] && CPP_FILES+=("$line")
done < <(staged_files '\.(c|cc|cpp|cxx|h|hpp|hxx|cu|cuh)$')

if [ ${#CPP_FILES[@]} -gt 0 ]; then
    CF="$(find_tool clang-format)"
    if [ -n "$CF" ]; then
        echo "[pre-commit] clang-format: ${#CPP_FILES[@]} file(s)"
        "$CF" -i "${CPP_FILES[@]}"
        restage_if_modified "${CPP_FILES[@]}"
    else
        echo "[pre-commit] WARNING: clang-format not found; skipping C/C++ formatting."
        any_warning=1
    fi
fi

# ---- Python via autopep8 -------------------------------------------------
PY_FILES=()
while IFS= read -r line; do
    [ -n "$line" ] && PY_FILES+=("$line")
done < <(staged_files '\.py$')

if [ ${#PY_FILES[@]} -gt 0 ]; then
    AP="$(find_tool autopep8)"
    if [ -n "$AP" ]; then
        echo "[pre-commit] autopep8: ${#PY_FILES[@]} file(s)"
        "$AP" --in-place "${PY_FILES[@]}"
        restage_if_modified "${PY_FILES[@]}"
    else
        echo "[pre-commit] WARNING: autopep8 not found; skipping Python formatting."
        echo "[pre-commit]          Install: pip install autopep8"
        any_warning=1
    fi
fi

# ---- Jupyter notebooks via nbstripout ------------------------------------
NB_FILES=()
while IFS= read -r line; do
    [ -n "$line" ] && NB_FILES+=("$line")
done < <(staged_files '\.ipynb$')

if [ ${#NB_FILES[@]} -gt 0 ]; then
    NB="$(find_tool nbstripout)"
    if [ -n "$NB" ]; then
        echo "[pre-commit] nbstripout: ${#NB_FILES[@]} notebook(s)"
        # --drop-empty-cells keeps diffs small; default strips outputs+exec counts.
        # --keep-metadata is NOT passed: we strip metadata too, as requested.
        "$NB" "${NB_FILES[@]}"
        restage_if_modified "${NB_FILES[@]}"
    else
        echo "[pre-commit] WARNING: nbstripout not found; skipping notebook stripping."
        echo "[pre-commit]          Install: pip install nbstripout"
        any_warning=1
    fi
fi

# Never block the commit on missing tools; only real formatter errors (which
# would exit non-zero under `set -e`) should fail. We intentionally ran
# without `-e` so a single formatter failure doesn't abort the others.
exit 0
